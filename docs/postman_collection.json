      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"dateOfBirth\": \"1985-05-15\",\n  \"gender\": \"MALE\",\n  \"phoneNumber\": \"555-123-4567\",\n  \"email\": \"john.doe@example.com\",\n  \"addressLine1\": \"123 Main St\",\n  \"addressLine2\": \"Apt 4B\",\n  \"city\": \"Baltimore\",\n  \"state\": \"Maryland\",\n  \"zipCode\": \"21201\",\n  \"country\": \"USA\",\n  \"bloodGroup\": \"O+\",\n  \"emergencyContactName\": \"Jane Doe\",\n  \"emergencyContactPhone\": \"555-987-6543\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"patientId\", jsonData.patientId || jsonData.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "url": {
