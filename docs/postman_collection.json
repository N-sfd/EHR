              "path": ["api", "appointments", "{{appointmentId}}"]
            }
          }
        },
        {
          "name": "Query Appointments (Grid)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/appointments?start=2026-01-12&end=2026-01-18&providerIds={{doctorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"],
              "query": [
                {
                  "key": "start",
                  "value": "2026-01-12"
                },
                {
                  "key": "end",
                  "value": "2026-01-18"
                },
                {
                  "key": "providerIds",
                  "value": "{{doctorId}}"
                }
              ]
            }
          }
        },
