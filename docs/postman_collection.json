    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"providerId\": {{doctorId}},\n  \"departmentId\": 1,\n  \"startDateTime\": \"2026-01-15T10:00:00\",\n  \"endDateTime\": \"2026-01-15T10:30:00\",\n  \"durationMinutes\": 30,\n  \"visitType\": \"FOLLOW_UP\",\n  \"status\": \"SCHEDULED\",\n  \"priority\": \"NORMAL\",\n  \"reason\": \"Annual checkup\",\n  \"notes\": \"Patient requested morning appointment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
