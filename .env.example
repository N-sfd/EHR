# Copy to .env and adjust for production (docker compose loads .env automatically)

APP_PORT=8080

POSTGRES_DB=staff_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# Set true when served over HTTPS (e.g. behind TLS terminator)
APP_COOKIE_SECURE=false
EPIC_SMART_COOKIE_SECURE=false

# Public URL of your deployment (no trailing slash on base; paths are appended in app-docker.yml)
EPIC_SMART_REDIRECT_URI=http://localhost:8080/api/patient/smart/callback
EPIC_SMART_FRONTEND_BASE_URL=http://localhost:8080/mychart

# Optional AI (requires OPENAI_API_KEY and pgvector — included in db image)
EHR_AI_ENABLED=false
OPENAI_API_KEY=
