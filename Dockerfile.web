# Admin portal + MyChart static sites behind NGINX
FROM node:20-alpine AS admin-build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend ./
RUN npm run build -- --configuration=production

FROM node:20-alpine AS mychart-build
WORKDIR /app
COPY mychart/mychart-ui/package.json ./
RUN npm install
COPY mychart/mychart-ui ./
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx/docker.conf /etc/nginx/conf.d/default.conf
COPY --from=admin-build /app/dist/preclinic-frontend /usr/share/nginx/html/admin
# Angular 17+ emits into a "browser" subfolder; serve that so /mychart/index.html exists.
COPY --from=mychart-build /app/dist/mychart-ui/browser /usr/share/nginx/html/mychart
EXPOSE 80
